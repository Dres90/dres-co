# Public site URL (production: https://dres.co). Used for metadataBase and JSON-LD.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to "false" to hide Labs in the main nav (routes still exist if linked directly).
# NEXT_PUBLIC_SHOW_LABS=true

# Supabase (server-only — never expose to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for POST /api/weight (Siri Shortcuts: Authorization: Bearer <secret>)
WEIGHT_WEBHOOK_SECRET=
